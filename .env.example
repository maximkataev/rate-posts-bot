# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=  # Оставьте пустым, если пароль не установлен

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-5

# Google Gemini Configuration
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-flash-latest

# DeepSeek Configuration (опционально — без ключа DeepSeek просто не участвует в оценке)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# OpenRouter (Optional)
OPENROUTER_API_KEY=

# Logging
LOG_LEVEL=INFO

# Doppler Configuration (только если используете Doppler)
DOPPLER_TOKEN=your_doppler_token_here
DOPPLER_PROJECT=telegram-bot
DOPPLER_CONFIG=dev
